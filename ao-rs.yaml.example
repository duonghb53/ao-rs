# ao-rs configuration example
#
# Copy to `ao-rs.yaml` in your project root and customize.
# Run `ao-rs start` in a project directory to generate one automatically.

# Web dashboard port (default: 3000)
port: 3000

# ---------------------------------------------------------------------------
# Global defaults — applied to every session unless overridden per-project
# ---------------------------------------------------------------------------

defaults:
  runtime: tmux                   # tmux | process
  agent: claude-code              # claude-code | cursor | aider | codex
  workspace: worktree             # worktree (git worktree isolation)
  tracker: github                 # github
  notifiers: []                   # [] | [stdout, ntfy, desktop, discord]

  # Default orchestrator role config (spawned by `ao-rs orchestrator spawn`)
  orchestrator:
    agent: claude-code
    agent_config:
      permissions: permissionless

  # Default worker role config (spawned by the orchestrator)
  worker:
    agent: claude-code

  # Rules injected into every orchestrator's system prompt across all projects.
  # Project-level orchestrator_rules are appended after these.
  orchestrator_rules: |-
    After spawning a worker, do NOT stop. Run a monitoring loop:
    1. Immediately confirm spawn with: ao-rs status
    2. Every 5 minutes, check: ao-rs status --project <id>
    3. When worker reaches pr_open/review_pending/merged/ci_failed → act
    4. Only stop monitoring when all workers reach terminal state (merged/killed)

    NEVER call `ao-rs cleanup` — it permanently archives sessions off-disk, making them
    invisible in the dashboard. Merged/killed sessions must remain visible so the user can
    review them. Only the user decides when to archive.

    When writing tests (and when instructing workers to write tests):
    - Tests MUST be inline `#[cfg(test)] mod tests` inside the SAME source file being changed.
    - Do NOT create separate integration test files unless testing cross-module behavior.
    - Run only the relevant module: `cargo t -p <crate> <module_name>`
    - Never write tests for compiler-provable things (type correctness, exhaustive match, etc.).

# ---------------------------------------------------------------------------
# Projects
# ---------------------------------------------------------------------------

projects:
  my-project:
    repo: owner/my-project          # GitHub repo (owner/repo)
    path: /path/to/my-project       # Absolute local path
    default_branch: main
    agent: claude-code              # Override global default agent for this project
    agent_config:
      permissions: permissionless
      model: sonnet                 # Worker model (sonnet | opus | haiku)
      orchestratorModel: opus       # Orchestrator model override
      rules: |-
        - Source porting from: ~study/agent-orchestrator, refer to it for intent.
        - When spawned from an issue, use the dev-lifecycle workflow to turn the
          issue content into concrete requirements and a plan, then execute it.
        - If stuck for more than 5 minutes, explain what's blocking you.

        Testing rules (strict — follow exactly):
        - Use `cargo t` (nextest alias) — NOT `cargo test`.
        - Run `cargo test --doc` separately for doctests (nextest skips them).
        - Tests MUST be inline `#[cfg(test)] mod tests` at the bottom of the SAME file changed.
        - Run only your module's tests during development: `cargo t -p <crate> <module>`
        - Before opening a PR: `cargo t --workspace && cargo test --doc --workspace &&
          cargo clippy --workspace --all-targets -- -D warnings && cargo fmt --all -- --check`

    # Orchestrator rules for this project (appended after defaults.orchestrator_rules)
    orchestrator_rules: |-
      You are the orchestrator for my-project.
      Delegate implementation to workers.

# ---------------------------------------------------------------------------
# Reactions — what to do when a session state changes
# ---------------------------------------------------------------------------

reactions:
  approved-and-green:
    action: notify
    priority: urgent

  merge-conflicts:
    action: send-to-agent
    message: Your branch has merge conflicts. Rebase on the default branch and resolve them.
    priority: action
    escalate_after: 15m

  agent-idle:
    action: send-to-agent
    message: You appear to be idle. If your task is not complete, continue working or explain blockers.
    priority: info
    retries: 2
    escalate_after: 15m

  agent-needs-input:
    action: notify
    priority: urgent

  agent-stuck:
    action: send-to-agent
    message: "You appear stuck. Continue work or explain blockers."
    threshold: 10m
    retries: 2
    escalate_after: 15m

  changes-requested:
    action: send-to-agent
    message: There are review comments on your PR. Check with `gh pr view --comments`, address them, and push.
    priority: action
    escalate_after: 30m

  agent-exited:
    action: notify
    priority: urgent

  all-complete:
    action: notify
    priority: info
    include_summary: true

# ---------------------------------------------------------------------------
# Notification routing by priority level
# ---------------------------------------------------------------------------

notification_routing:
  urgent:
    - stdout
  info:
    - stdout
  warning:
    - stdout
  action:
    - stdout

# ---------------------------------------------------------------------------
# Optional notifier configs (uncomment to enable)
# ---------------------------------------------------------------------------

# Environment variables for push notifiers:
#   AO_NTFY_TOPIC          ntfy.sh topic
#   AO_NTFY_URL            custom ntfy server (default: https://ntfy.sh)
#   AO_DISCORD_WEBHOOK_URL Discord webhook URL
#   AO_SLACK_WEBHOOK_URL   Slack incoming webhook URL

# Advanced reaction example:
# reactions:
#   ci-failed:
#     action: send-to-agent
#     message: "CI failed. Read the logs with `gh run view --log-failed`, fix the issue, and push."
#     retries: 3
#     escalate_after: 30m
#   approved-and-green:
#     action: auto-merge
#     merge_method: squash   # merge | squash | rebase
